

<style>
    .reviews-section {
        background: linear-gradient(135deg, #f8f9fa 0%, #e8ecf1 100%);
        padding: 10px 0;
        position: relative;
        overflow: hidden;
    }

    .reviews-section::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -10%;
        width: 600px;
        height: 600px;
        background: rgba(43, 179, 163, 0.06);
        border-radius: 50%;
        z-index: 1;
    }

    .reviews-section::after {
        content: '';
        position: absolute;
        bottom: -30%;
        right: -5%;
        width: 500px;
        height: 500px;
        background: rgba(43, 179, 163, 0.04);
        border-radius: 50%;
        z-index: 1;
    }

    .reviews-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 20px;
        position: relative;
        z-index: 2;
    }

    .reviews-header {
        text-align: center;
        margin-bottom: 20px;
    }

    .reviews-header h2 {
        font-size: 48px;
        font-weight: 800;
        color: #222;
        margin-bottom: 15px;
        letter-spacing: -0.5px;
    }

    .reviews-header h2 span {
        color: #2bb3a3;
    }

    .reviews-header p {
        font-size: 18px;
        color: #666;
        max-width: 600px;
        margin: 0 auto;
    }

    .reviews-content {
        display: block;
        max-width: 1200px;
        margin: 0 auto;
    }

    /* --- Testimonials Carousel --- */
    .testimonials-carousel {
        position: relative;
    }

    .testimonials-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 30px;
        margin-bottom: 40px;
    }

    .testimonial-card {
        background: white;
        border-radius: 15px;
        overflow: hidden;
        box-shadow: 0 10px 35px rgba(0, 0, 0, 0.1);
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        cursor: pointer;
        position: relative;
    }

    .testimonial-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.15);
    }

    .testimonial-image {
        position: relative;
        width: 100%;
        height: 280px;
        background: linear-gradient(135deg, #2bb3a3 0%, #1f8b7a 100%);
        overflow: hidden;
    }

    .testimonial-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .play-button {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 60px;
        height: 60px;
        background: rgba(255, 255, 255, 0.95);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
        z-index: 10;
    }

    .testimonial-card:hover .play-button {
        background: white;
        transform: translate(-50%, -50%) scale(1.1);
    }

    .play-button i {
        color: #2bb3a3;
        font-size: 24px;
        margin-left: 3px;
    }

    .testimonial-body {
        padding: 25px;
    }

    .testimonial-name {
        font-size: 18px;
        font-weight: 700;
        color: #2bb3a3;
        margin-bottom: 8px;
    }

    .testimonial-quote {
        font-size: 14px;
        color: #666;
        line-height: 1.6;
        margin-bottom: 12px;
        font-style: italic;
    }

    .testimonial-rating {
        display: flex;
        gap: 5px;
        margin-bottom: 0;
    }

    .testimonial-rating i {
        color: #ffc107;
        font-size: 14px;
    }

    /* --- Video Testimonial Cards --- */
    .video-testimonial-card {
        background: white;
        border-radius: 15px;
        overflow: hidden;
        box-shadow: 0 10px 35px rgba(0, 0, 0, 0.1);
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        cursor: pointer;
        position: relative;
    }

    .video-testimonial-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.15);
    }

    .video-image {
        position: relative;
        width: 100%;
        height: 280px;
        background: linear-gradient(135deg, #2bb3a3 0%, #1f8b7a 100%);
        overflow: hidden;
    }

    .video-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .video-play-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.3);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.4s ease;
        z-index: 5;
    }

    .video-testimonial-card:hover .video-play-overlay {
        background: rgba(0, 0, 0, 0.6);
    }

    .video-play-button {
        width: 70px;
        height: 70px;
        background: rgba(255, 255, 255, 0.95);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
        z-index: 10;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
    }

    .video-testimonial-card:hover .video-play-button {
        background: white;
        transform: scale(1.25);
        box-shadow: 0 15px 45px rgba(0, 0, 0, 0.3);
    }

    .video-play-button i {
        color: #2bb3a3;
        font-size: 28px;
        margin-left: 3px;
        transition: all 0.3s ease;
    }

    .video-testimonial-card:hover .video-play-button i {
        color: #1f8b7a;
        transform: scale(1.1);
    }

    .video-info {
        padding: 25px;
    }

    .video-title {
        font-size: 18px;
        font-weight: 700;
        color: #2bb3a3;
        margin-bottom: 8px;
    }

    .video-desc {
        font-size: 14px;
        color: #666;
        line-height: 1.6;
        margin-bottom: 12px;
    }

    .video-rating {
        display: flex;
        gap: 5px;
        margin-bottom: 0;
    }

    .video-rating i {
        color: #ffc107;
        font-size: 14px;
    }

    .testimonials-pagination {
        display: flex;
        justify-content: center;
        gap: 12px;
        flex-wrap: wrap;
    }

    .pagination-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: rgba(43, 179, 163, 0.3);
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .pagination-dot:hover {
        background: rgba(43, 179, 163, 0.6);
    }

    .pagination-dot.active {
        background: #2bb3a3;
        width: 28px;
        border-radius: 5px;
    }

    .testimonials-grid {
        animation: fadeIn 0.5s ease;
    }

    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .pagination-nav {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 20px;
        margin-top: 30px;
    }

    .pagination-btn {
        width: 40px;
        height: 40px;
        border: 2px solid #2bb3a3;
        background: white;
        color: #2bb3a3;
        border-radius: 50%;
        cursor: pointer;
        font-size: 18px;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .pagination-btn:hover {
        background: #2bb3a3;
        color: white;
        transform: scale(1.1);
    }

    .pagination-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .page-counter {
        font-size: 14px;
        color: #666;
        font-weight: 600;
    }

    /* --- Feedback Form --- */
    .feedback-form-wrapper {
        background: white;
        padding: 40px;
        border-radius: 20px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
        position: sticky;
        top: 100px;
        animation: slideInRight 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(43, 179, 163, 0.1);
    }

    @keyframes slideInRight {
        from {
            opacity: 0;
            transform: translateX(50px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    .feedback-form-header {
        margin-bottom: 35px;
        animation: fadeInUp 0.6s ease 0.1s both;
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .feedback-form-header h3 {
        font-size: 28px;
        font-weight: 800;
        color: #222;
        margin-bottom: 8px;
        letter-spacing: -0.5px;
    }

    .feedback-form-header h3 span {
        color: #2bb3a3;
        position: relative;
    }

    .feedback-form-header h3 span::after {
        content: '';
        position: absolute;
        bottom: -3px;
        left: 0;
        width: 100%;
        height: 3px;
        background: linear-gradient(90deg, #2bb3a3, #1f8b7a);
        border-radius: 2px;
    }

    .feedback-form-header p {
        font-size: 14px;
        color: #2bb3a3;
        margin-bottom: 0;
        font-weight: 600;
        letter-spacing: 0.5px;
        text-transform: uppercase;
    }

    .form-group {
        margin-bottom: 28px;
        animation: fadeInUp 0.6s ease backwards;
    }

    .form-group:nth-child(2) { animation-delay: 0.15s; }
    .form-group:nth-child(3) { animation-delay: 0.2s; }
    .form-group:nth-child(4) { animation-delay: 0.25s; }
    .form-group:nth-child(5) { animation-delay: 0.3s; }
    .form-group:nth-child(6) { animation-delay: 0.35s; }

    .form-group label {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 13px;
        font-weight: 700;
        color: #333;
        margin-bottom: 12px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        transition: all 0.3s ease;
    }

    .form-group label i {
        color: #2bb3a3;
        font-size: 18px;
        transition: all 0.3s ease;
    }

    .form-group input[type="text"],
    .form-group textarea {
        width: 100%;
        padding: 14px 18px;
        border: 2px solid #e5e5e5;
        border-radius: 12px;
        font-size: 14px;
        font-family: inherit;
        transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
        background: linear-gradient(135deg, #f9f9f9 0%, #ffffff 100%);
        color: #333;
    }

    .form-group input[type="text"]::placeholder,
    .form-group textarea::placeholder {
        color: #bbb;
        transition: all 0.3s ease;
    }

    .form-group input[type="text"]:hover,
    .form-group textarea:hover {
        border-color: #2bb3a3;
        box-shadow: 0 5px 20px rgba(43, 179, 163, 0.08);
    }

    .form-group input[type="text"]:focus,
    .form-group textarea:focus {
        outline: none;
        border-color: #2bb3a3;
        background: white;
        box-shadow: 0 8px 35px rgba(43, 179, 163, 0.16);
        transform: translateY(-2px);
    }

    .form-group input[type="text"]:focus + label,
    .form-group textarea:focus + label {
        color: #2bb3a3;
    }

    .form-group textarea {
        resize: vertical;
        min-height: 120px;
        font-size: 14px;
        line-height: 1.5;
    }

    .rating-stars {
        display: flex;
        gap: 16px;
        margin-bottom: 0;
        position: relative;
        padding: 20px 15px;
        background: linear-gradient(135deg, rgba(43, 179, 163, 0.05), rgba(31, 139, 122, 0.05));
        border-radius: 15px;
        border: 2px dashed rgba(43, 179, 163, 0.2);
        justify-content: center;
        transition: all 0.4s ease;
    }

    .rating-stars:hover {
        border-color: rgba(43, 179, 163, 0.4);
        background: linear-gradient(135deg, rgba(43, 179, 163, 0.1), rgba(31, 139, 122, 0.08));
        box-shadow: 0 10px 30px rgba(43, 179, 163, 0.1);
    }

    .star {
        font-size: 50px;
        color: #e0e0e0;
        cursor: pointer;
        transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
        filter: drop-shadow(0 3px 6px rgba(0, 0, 0, 0.08));
        position: relative;
        background: linear-gradient(135deg, transparent 0%, rgba(255, 193, 7, 0) 100%);
        background-clip: text;
        -webkit-background-clip: text;
        will-change: transform, filter;
    }

    .star::before {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        width: 50px;
        height: 50px;
        background: radial-gradient(circle, rgba(255, 193, 7, 0.3) 0%, transparent 70%);
        border-radius: 50%;
        transform: translate(-50%, -50%) scale(0);
        transition: all 0.4s ease;
        pointer-events: none;
    }

    .star:hover {
        color: #ffc107;
        transform: scale(1.15) translateY(-6px);
        filter: drop-shadow(0 8px 20px rgba(255, 193, 7, 0.5));
    }

    .star:hover::before {
        transform: translate(-50%, -50%) scale(1);
    }

    .star.active {
        color: #ffc107;
        transform: scale(1.35) rotate(10deg);
        animation: starFillBurst 0.7s cubic-bezier(0.34, 1.56, 0.64, 1);
        filter: drop-shadow(0 10px 30px rgba(255, 193, 7, 0.6));
        text-shadow: 0 0 20px rgba(255, 193, 7, 0.8);
    }

    .star.active::before {
        animation: starGlow 0.7s ease;
    }

    @keyframes starFillBurst {
        0% {
            transform: scale(0.5) rotate(-20deg);
            opacity: 0;
            filter: drop-shadow(0 0 0 rgba(255, 193, 7, 0));
        }
        30% {
            filter: drop-shadow(0 15px 40px rgba(255, 193, 7, 0.8));
        }
        60% {
            transform: scale(1.45) rotate(15deg);
        }
        100% {
            transform: scale(1.35) rotate(10deg);
            opacity: 1;
            filter: drop-shadow(0 10px 30px rgba(255, 193, 7, 0.6));
        }
    }

    @keyframes starGlow {
        0% {
            transform: translate(-50%, -50%) scale(0);
            opacity: 1;
        }
        100% {
            transform: translate(-50%, -50%) scale(2);
            opacity: 0;
        }
    }

    @keyframes sparkle {
        0%, 100% {
            opacity: 0;
            transform: scale(0);
        }
        50% {
            opacity: 1;
            transform: scale(1);
        }
    }

    /* Particle sparks around active stars */
    .star.active::after {
        content: '✨';
        position: absolute;
        animation: sparkleParticles 0.8s ease-out;
        pointer-events: none;
        font-size: 16px;
    }

    @keyframes sparkleParticles {
        0% {
            transform: translate(0, 0) scale(1);
            opacity: 1;
        }
        100% {
            transform: translate(var(--tx), var(--ty)) scale(0);
            opacity: 0;
        }
    }

    /* Fill animation for sequential star coloring */
    .star.filled {
        animation: fillWave 0.5s ease;
    }

    @keyframes fillWave {
        0% {
            color: #e0e0e0;
        }
        50% {
            color: #ffd700;
        }
        100% {
            color: #ffc107;
        }
    }

    /* Rating display with animation */
    .rating-display {
        font-size: 14px;
        font-weight: 700;
        color: #2bb3a3;
        text-align: center;
        opacity: 0;
        transform: translateY(-10px);
        transition: all 0.4s ease;
        min-height: 20px;
        margin-top: 12px;
    }

    .rating-display.show {
        opacity: 1;
        transform: translateY(0);
    }

    /* Particle animation */
    .particle {
        animation: sparkleParticles 0.8s ease-out forwards;
    }

    .submit-btn {
        width: 100%;
        padding: 16px 24px;
        background: linear-gradient(135deg, #2bb3a3 0%, #1f8b7a 100%);
        color: white;
        border: none;
        border-radius: 12px;
        font-size: 16px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        text-transform: uppercase;
        letter-spacing: 1px;
        box-shadow: 0 10px 30px rgba(43, 179, 163, 0.25);
        position: relative;
        overflow: hidden;
        animation: fadeInUp 0.6s ease 0.4s both;
    }

    .submit-btn::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
        transition: left 0.5s ease;
    }

    .submit-btn:hover {
        transform: translateY(-4px);
        box-shadow: 0 18px 50px rgba(43, 179, 163, 0.4);
    }

    .submit-btn:hover::before {
        left: 100%;
    }

    .submit-btn:active {
        transform: translateY(-1px);
        box-shadow: 0 8px 20px rgba(43, 179, 163, 0.3);
    }

    .submit-btn i {
        transition: all 0.3s ease;
    }

    .submit-btn:hover i {
        transform: translateX(3px);
    }

    .form-success {
        background: linear-gradient(135deg, #d4edda 0%, #c3e6cb 100%);
        color: #155724;
        padding: 18px 20px;
        border-radius: 12px;
        margin-bottom: 25px;
        display: none;
        align-items: center;
        gap: 12px;
        border: 2px solid #c3e6cb;
        box-shadow: 0 8px 25px rgba(21, 87, 36, 0.15);
        animation: slideInDown 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
        font-weight: 600;
    }

    @keyframes slideInDown {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .form-success i {
        font-size: 22px;
        animation: checkPulse 0.6s ease;
    }

    @keyframes checkPulse {
        0%, 100% {
            transform: scale(1);
        }
        50% {
            transform: scale(1.2);
        }
    }

    .form-success.show {
        display: flex;
    }

    /* --- Responsive --- */
    @media (max-width: 1024px) {
        .reviews-content {
            grid-template-columns: 2fr 1.2fr;
            gap: 40px;
        }

        .feedback-form-wrapper {
            position: sticky;
            top: 100px;
        }

        .testimonials-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 768px) {
        .reviews-section {
            padding: 60px 0;
        }

        .reviews-header h2 {
            font-size: 32px;
        }

        .reviews-content {
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .testimonials-grid {
            grid-template-columns: 1fr;
            gap: 20px;
        }

        .feedback-form-wrapper {
            padding: 30px;
            position: sticky;
            top: 100px;
        }

        .testimonial-image,
        .video-image {
            height: 220px;
        }
    }

    @media (max-width: 576px) {
        .reviews-content {
            grid-template-columns: 1fr;
            gap: 30px;
        }

        .feedback-form-wrapper {
            position: relative;
            top: auto;
            padding: 25px;
        }

        .reviews-header h2 {
            font-size: 24px;
        }

        .testimonials-grid {
            grid-template-columns: 1fr;
            gap: 15px;
        }

        .testimonial-image,
        .video-image {
            height: 200px;
        }

        .pagination-nav {
            gap: 15px;
            margin-top: 20px;
        }
    }
</style>


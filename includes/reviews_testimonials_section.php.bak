                        </div>
                    </div>
                    <?php endforeach; ?>
                </div>

                <!-- Pagination Controls -->
                <div class="pagination-nav">
                    <button class="pagination-btn" id="prev-btn" onclick="prevPage()" title="Previous">
                        <i class="fas fa-chevron-left"></i>
                    </button>
                    <div class="testimonials-pagination" id="pagination-dots"></div>
                    <button class="pagination-btn" id="next-btn" onclick="nextPage()" title="Next">
                        <i class="fas fa-chevron-right"></i>
                    </button>
                </div>
                <div class="text-center mt-3">
                    <span class="page-counter"><span id="current-page">1</span> / <span id="total-pages">1</span> Stories</span>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    let currentPage = 0;
    const cardsPerPage = 6;
    const totalCards = document.querySelectorAll('.video-testimonial-card').length;
    const totalPages = Math.ceil(totalCards / cardsPerPage);

    function initPagination() {
        const container = document.getElementById('pagination-dots');
        if (!container) return;
        container.innerHTML = '';
        for (let i = 0; i < totalPages; i++) {
            const dot = document.createElement('div');
            dot.className = `pagination-dot ${i === 0 ? 'active' : ''}`;
            dot.onclick = () => goToPage(i);
            container.appendChild(dot);
        }
        updateButtons();
        showPage(0);
    }

    function showPage(page) {
        const allCards = document.querySelectorAll('.video-testimonial-card');
        allCards.forEach((card, index) => {
            const start = page * cardsPerPage;
            const end = start + cardsPerPage;
            if (index >= start && index < end) {
                card.style.display = 'block';
                card.style.animation = 'fadeIn 0.5s ease';
            } else {
                card.style.display = 'none';
                const video = card.querySelector('video');
                if (video) {
                    video.pause();
                    video.currentTime = 0;
                }
            }
        });

        document.querySelectorAll('.pagination-dot').forEach((dot, index) => {
            dot.classList.toggle('active', index === page);
        });

        const curPageEl = document.getElementById('current-page');
        const totPageEl = document.getElementById('total-pages');
        if (curPageEl) curPageEl.textContent = page + 1;
        if (totPageEl) totPageEl.textContent = totalPages;
        updateButtons();
    }

    function nextPage() {
        if (currentPage < totalPages - 1) {
            currentPage++;
            showPage(currentPage);
        }
    }

    function prevPage() {
        if (currentPage > 0) {
            currentPage--;
            showPage(currentPage);
        }
    }

    function goToPage(page) {
        currentPage = page;
        showPage(currentPage);
    }

    function updateButtons() {
        const prevBtn = document.getElementById('prev-btn');
        const nextBtn = document.getElementById('next-btn');
        if (prevBtn) prevBtn.disabled = currentPage === 0;
        if (nextBtn) nextBtn.disabled = currentPage === totalPages - 1;
    }

    // Video Modal Optimized for MP4
    function openVideoModal(videoUrl) {
        let modal = document.getElementById('video-modal');
        if (!modal) {
            modal = document.createElement('div');
            modal.id = 'video-modal';
            modal.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.95);display:none;align-items:center;justify-content:center;z-index:9999;backdrop-filter:blur(10px);';
            modal.innerHTML = `<div style="position:relative;width:90%;max-width:800px;background:#000;border-radius:15px;overflow:hidden;box-shadow:0 0 50px rgba(43,179,163,0.3);">
                <button onclick="closeVideoModal()" style="position:absolute;top:15px;right:15px;background:rgba(255,255,255,0.2);border:none;width:35px;height:35px;border-radius:50%;cursor:pointer;color:#fff;font-size:20px;z-index:1001;">×</button>
                <div id="video-container"></div>
            </div>`;
            document.body.appendChild(modal);
        }
        
        const container = modal.querySelector('#video-container');
        if (videoUrl.includes('.mp4')) {
            container.innerHTML = `<video width="100%" height="auto" controls autoplay style="display:block;">
                <source src="${videoUrl}" type="video/mp4">
                Your browser does not support the video tag.
            </video>`;
        } else {
            container.innerHTML = `<iframe width="100%" height="450" src="${videoUrl}?autoplay=1" frameborder="0" allow="autoplay; encrypted-media" allowfullscreen></iframe>`;
        }
        
        modal.style.display = 'flex';
        document.body.style.overflow = 'hidden';
    }

    function closeVideoModal() {
        const modal = document.getElementById('video-modal');
        if (modal) {
            modal.style.display = 'none';
            modal.querySelector('#video-container').innerHTML = '';
            document.body.style.overflow = 'auto';
        }
    }

    window.addEventListener('load', initPagination);
</script>

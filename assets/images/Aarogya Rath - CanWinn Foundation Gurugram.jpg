        /*------------------------------------
  Content Centered
------------------------------------*/
        .content-centered-y {
            position: absolute;
            top: 50%;
            -webkit-transform: translate(0, -50%);
            transform: translate(0, -50%);
        }

        @media (min-width: 768px) {
            .content-centered-y--md {
                position: absolute;
                top: 50%;
                -webkit-transform: translate(0, -50%);
                transform: translate(0, -50%);

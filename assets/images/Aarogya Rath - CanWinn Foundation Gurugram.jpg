        /*------------------------------------
  Position Spaces
------------------------------------*/
        .top-0 {
            top: 0;
        }

        .right-0 {
            right: 0;
        }

        .bottom-0 {
            bottom: 0;
        }

        .left-0 {
            left: 0;
        }

        @media (min-width: 576px) {
            .position-sm-absolute {
                position: absolute;
            }
        }

        @media (min-width: 768px) {
            .top-md-0 {
                top: 0;
            }

            .right-md-0 {
                right: 0;
            }

            .bottom-md-0 {
                bottom: 0;
            }

            .left-md-0 {
                left: 0;

        }

        .u-avatar .rounded-circle+.badge-md.badge-pos--bottom-left {
            -webkit-transform: translate(-30%, 30%);
            transform: translate(-30%, 30%);
        }

        .u-avatar .rounded-circle+.badge-md.badge-pos--bottom-right {
            -webkit-transform: translate(30%, 30%);
            transform: translate(30%, 30%);
        }

        /* Small Size Avatar */

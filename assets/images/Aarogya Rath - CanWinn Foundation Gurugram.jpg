        }

        .u-header__banner::after {
            position: absolute;
            top: 0;
            right: 0;
            bottom: 0;
            left: 0;
            background-color: rgba(30, 32, 34, 0);
            border-bottom-left-radius: 0.3125rem;
            content: "";
        }


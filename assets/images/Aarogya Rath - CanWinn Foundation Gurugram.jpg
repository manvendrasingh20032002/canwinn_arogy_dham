(function($){
                if (!$) {
                    return;
                }

				function escAttr(text) {
					return text.replace(/&/g, "&amp;")
						.replace(/</g, "&lt;")
						.replace(/>/g, "&gt;")
						.replace(/"/g, "&quot;")
						.replace(/"/g, "&#039;");
				}

				$(document).on("click", "[data-fancybox]", function (e) {
					const $this = $(this);
					const caption = $this.attr("data-caption");

					if (caption) {
						$this.attr("data-caption", escAttr(caption));
					}
				});
            }(window.jQuery));
//# sourceURL=fancybox-js-before

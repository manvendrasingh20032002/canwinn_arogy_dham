        /*------------------------------------
  Button Sizes
------------------------------------*/
        /* Wide */
        .btn-wide {
            min-width: 9.6875rem;
        }

        .btn-sm-wide {
            min-width: 8.4375rem;
        }

        /* Extra Small */
        .btn-xs {
            font-size: 0.6875rem;
            font-weight: 400;
            padding: 0.4375rem 0.9375rem;
        }

        /* Icons */
        .btn-icon.btn-xs {
            font-size: 0.75rem;
            width: 1.5rem;
            height: 1.5rem;
        }

        .btn-icon.btn-sm,
        .btn-group-sm>.btn-icon.btn {
            font-size: 0.8175rem;
            width: 2rem;
            height: 2rem;
        }

        .btn-icon.btn-lg,
        .btn-group-lg>.btn-icon.btn {
            font-size: 1.75rem;
            width: 5rem;
            height: 5rem;
        }

        /*------------------------------------
  Text Buttons Styles
------------------------------------*/
        /* primary text button */
        .btn-text-primary {
            color: #377dff;
            background: transparent;
        }

        .btn-text-primary[href]:hover,

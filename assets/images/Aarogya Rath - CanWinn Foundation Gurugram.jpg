        }

        .u-dropzone .dz-details {
            margin-bottom: 1rem;
        }

        .u-dropzone .dz-file-preview {
            background-color: #fff;
            border-radius: 0.3125rem;
            padding: 1rem;
            box-shadow: 0 3px 6px 0 rgba(140, 152, 164, 0.25);

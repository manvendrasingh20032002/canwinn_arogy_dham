    z-index: 1;
    margin-top: -4px;
  }

  .why-resp-wrapper::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 50%;
    background: url(../images/why-medanta-res-bg.png) no-repeat;
    background-size: cover;

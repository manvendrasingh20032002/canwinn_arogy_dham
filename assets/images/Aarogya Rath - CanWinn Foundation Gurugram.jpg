        /*------------------------------------
  Fileuploader
------------------------------------*/
        /* Default Style */
        .fileuploader {
            margin-top: 0;
        }

        /* Front Style */
        .u-fileuploader-input {
            display: block;
            cursor: pointer;
            background: #fff;
            border: 2px dashed #e7eaf3;
